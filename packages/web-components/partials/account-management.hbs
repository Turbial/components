<!-- account-management: profile/settings card. Hand-authored (no free
     library match found) in the same style as account-auth.hbs. Relies on
     the same CSS variables every template defines on its root wrapper. -->
<section style="padding:72px 24px;display:flex;justify-content:center;background:var(--bg,#fafafa);">
  <div style="width:100%;max-width:480px;background:var(--surface,#fff);border:1px solid var(--border,#e5e5e5);border-radius:var(--radius-lg,16px);box-shadow:var(--shadow,0 1px 3px rgba(0,0,0,.08));padding:32px;">
    <h2 style="margin:0 0 6px;font-family:'Space Grotesk',sans-serif;font-size:22px;font-weight:700;color:var(--text,#18181b);">
      {{#if account.title}}{{account.title}}{{else}}Account settings{{/if}}
    </h2>
    <p style="margin:0 0 24px;font-size:14px;color:var(--muted,#71717a);">
      {{#if account.subtitle}}{{account.subtitle}}{{else}}Update your {{business.name}} profile details{{/if}}
    </p>

    <form method="post" action="{{#if account.updateAction}}{{account.updateAction}}{{else}}#{{/if}}" style="display:flex;flex-direction:column;gap:16px;">
      <div>
        <label for="name" style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:var(--text,#18181b);">Full name</label>
        <input id="name" name="name" type="text" value="{{account.name}}" placeholder="Jane Doe"
          style="width:100%;padding:10px 12px;border:1px solid var(--border,#e5e5e5);border-radius:8px;font-size:14px;background:var(--bg,#fff);color:var(--text,#18181b);">
      </div>
      <div>
        <label for="settings-email" style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:var(--text,#18181b);">Email</label>
        <input id="settings-email" name="email" type="email" value="{{account.email}}" placeholder="you@example.com"
          style="width:100%;padding:10px 12px;border:1px solid var(--border,#e5e5e5);border-radius:8px;font-size:14px;background:var(--bg,#fff);color:var(--text,#18181b);">
      </div>
      <div>
        <label for="phone" style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:var(--text,#18181b);">Phone</label>
        <input id="phone" name="phone" type="tel" value="{{account.phone}}" placeholder="(555) 555-5555"
          style="width:100%;padding:10px 12px;border:1px solid var(--border,#e5e5e5);border-radius:8px;font-size:14px;background:var(--bg,#fff);color:var(--text,#18181b);">
      </div>

      <hr style="border:none;border-top:1px solid var(--border,#e5e5e5);margin:8px 0;">

      <div>
        <label for="new-password" style="display:block;margin-bottom:6px;font-size:13px;font-weight:600;color:var(--text,#18181b);">New password</label>
        <input id="new-password" name="newPassword" type="password" placeholder="Leave blank to keep current password"
          style="width:100%;padding:10px 12px;border:1px solid var(--border,#e5e5e5);border-radius:8px;font-size:14px;background:var(--bg,#fff);color:var(--text,#18181b);">
      </div>

      <button type="submit" style="width:100%;padding:11px;border:none;border-radius:var(--radius,10px);background:var(--accent,#18181b);color:#fff;font-size:14.5px;font-weight:600;cursor:pointer;">
        Save changes
      </button>
    </form>

    <p style="margin:24px 0 0;text-align:center;font-size:13.5px;">
      <a href="{{#if account.deleteAccountUrl}}{{account.deleteAccountUrl}}{{else}}#{{/if}}" style="color:#b91c1c;text-decoration:underline;">Delete account</a>
    </p>
  </div>
</section>
