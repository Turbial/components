<!-- billing: pricing/plan card. Adapted from hyperui marketing/pricing/1
     (plan name, price, feature checklist). Relies on the same CSS variables
     every template defines on its root wrapper. Supports an array of plans
     via {{#each billing.plans}}; falls back to one example plan. -->
<section style="padding:72px 24px;background:var(--bg,#fafafa);">
  <div style="max-width:960px;margin:0 auto;text-align:center;">
    <h2 style="margin:0 0 8px;font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:700;color:var(--text,#18181b);">
      {{#if billing.title}}{{billing.title}}{{else}}Pricing{{/if}}
    </h2>
    <p style="margin:0 0 40px;font-size:15px;color:var(--muted,#71717a);">
      {{#if billing.subtitle}}{{billing.subtitle}}{{else}}Simple plans for every stage of {{business.name}}{{/if}}
    </p>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;max-width:960px;margin:0 auto;">
    {{#if billing.plans}}
      {{#each billing.plans}}
        <div style="background:var(--surface,#fff);border:1px solid {{#if this.featured}}var(--accent,#18181b){{else}}var(--border,#e5e5e5){{/if}};{{#if this.featured}}box-shadow:0 0 0 1px var(--accent,#18181b);{{/if}}border-radius:var(--radius-lg,16px);padding:32px;text-align:center;">
          <h3 style="margin:0 0 8px;font-size:16px;font-weight:600;color:var(--text,#18181b);">{{this.name}}</h3>
          <p style="margin:0 0 20px;">
            <strong style="font-size:34px;font-weight:700;color:var(--text,#18181b);">{{this.price}}</strong>
            <span style="font-size:13px;color:var(--muted,#71717a);">/{{this.period}}</span>
          </p>
          <ul style="list-style:none;margin:0 0 24px;padding:0;display:flex;flex-direction:column;gap:10px;text-align:left;">
            {{#each this.features}}
              <li style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text,#18181b);">
                <span style="color:var(--accent,#18181b);">&#10003;</span> {{this}}
              </li>
            {{/each}}
          </ul>
          <a href="{{#if this.checkoutUrl}}{{this.checkoutUrl}}{{else}}#{{/if}}" style="display:block;width:100%;padding:11px;border-radius:var(--radius,10px);background:{{#if this.featured}}var(--accent,#18181b){{else}}var(--surface,#fff){{/if}};color:{{#if this.featured}}#fff{{else}}var(--text,#18181b){{/if}};border:1px solid var(--border,#e5e5e5);font-size:14.5px;font-weight:600;text-decoration:none;box-sizing:border-box;">
            Choose {{this.name}}
          </a>
        </div>
      {{/each}}
    {{else}}
      <div style="background:var(--surface,#fff);border:1px solid var(--accent,#18181b);box-shadow:0 0 0 1px var(--accent,#18181b);border-radius:var(--radius-lg,16px);padding:32px;text-align:center;">
        <h3 style="margin:0 0 8px;font-size:16px;font-weight:600;color:var(--text,#18181b);">Pro</h3>
        <p style="margin:0 0 20px;">
          <strong style="font-size:34px;font-weight:700;color:var(--text,#18181b);">$30</strong>
          <span style="font-size:13px;color:var(--muted,#71717a);">/month</span>
        </p>
        <ul style="list-style:none;margin:0 0 24px;padding:0;display:flex;flex-direction:column;gap:10px;text-align:left;">
          <li style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text,#18181b);"><span style="color:var(--accent,#18181b);">&#10003;</span> 20 users included</li>
          <li style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text,#18181b);"><span style="color:var(--accent,#18181b);">&#10003;</span> 5GB of storage</li>
          <li style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text,#18181b);"><span style="color:var(--accent,#18181b);">&#10003;</span> Email support</li>
          <li style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text,#18181b);"><span style="color:var(--accent,#18181b);">&#10003;</span> Help center access</li>
        </ul>
        <a href="#" style="display:block;width:100%;padding:11px;border-radius:var(--radius,10px);background:var(--accent,#18181b);color:#fff;border:1px solid var(--border,#e5e5e5);font-size:14.5px;font-weight:600;text-decoration:none;box-sizing:border-box;">
          Choose Pro
        </a>
      </div>
    {{/if}}
  </div>
</section>
